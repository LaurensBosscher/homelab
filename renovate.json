{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "argocd",
    "dockerfile",
    "kustomize",
    "kubernetes"
  ],
  "dockerfile": {
    "managerFilePatterns": [
      "/(^|/)Dockerfile$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)openclaw/Dockerfile$/"
      ],
      "matchStrings": [
        "(?:RUN bun install\\s+|\\s+)(?<depName>(?:@[\\w.-]+/)?[\\w.-]+)@(?<currentValue>[^\\s&]+)"
      ],
      "datasourceTemplate": "npm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)openclaw/Dockerfile$/"
      ],
      "matchStrings": [
        "uv tool install (?<depName>[\\w.-]+)==(?<currentValue>[^\\s&]+)"
      ],
      "datasourceTemplate": "pypi"
    }
  ],
  "argocd": {
    "managerFilePatterns": [
      "/(^|/)apps/.+\\.ya?ml$/"
    ]
  },
  "kustomize": {
    "managerFilePatterns": [
      "/(^|/)apps/.+\\.ya?ml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/(^|/)apps/.+\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "matchManagers": [
        "kubernetes",
        "argocd",
        "kustomize"
      ],
      "matchDatasources": [
        "docker"
      ],
      "automerge": false,
      "prCreation": "immediate",
      "groupName": "container image updates"
    },
    {
      "matchPackageNames": [
        "getmeili/meilisearch"
      ],
      "enabled": false,
      "description": "Meilisearch needs to be updated manually"
    }
  ]
}
